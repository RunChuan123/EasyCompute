{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Linux CUDA Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "/root/autodl-tmp/EasyCompute/build/bin/exe_main",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}